generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String          @id @default(cuid())
  email       String          @unique
  name        String?
  role        String          @default("student")
  streak      Int             @default(0)
  points      Int             @default(0)
  currentWeek Int             @default(1)
  currentDay  Int             @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  sessions    ChatSession[]
  progress    TopicProgress[]
}

model TopicProgress {
  id               String   @id @default(cuid())
  userId           String
  topicDay         Int
  completed        Boolean  @default(false)
  notes            String?  @db.Text
  redTeamReportUrl String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicDay])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  tokens    Int?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Week {
  id     Int     @id
  title  String
  topics Topic[]
}

model Topic {
  id            Int      @id
  day           Int      @unique
  weekId        Int
  title         String
  skill         String
  hoursPerDay   String
  difficulty    String
  systemDesign  String   @db.Text
  miniProject   String   @db.Text
  mediumProject String?  @db.Text
  bigProject    String?  @db.Text
  testing       String   @db.Text
  audit         String   @db.Text
  resource      String
  redTeamTask   String   @db.Text
  gapFixed      String?
  steps         String[]
  proTip        String?  @db.Text
  detailedSteps Json?
  week          Week     @relation(fields: [weekId], references: [id])
}

model Project {
  id        Int    @id
  milestone Int    @unique
  mini      String @db.Text
  medium    String @db.Text
  big       String @db.Text
}

model GraduationChecklist {
  id       String   @id @default(cuid())
  category String   @unique
  items    String[]
}
