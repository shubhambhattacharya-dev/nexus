generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String          @id @default(cuid())
  email       String          @unique
  name        String?
  role        String          @default("student")
  streak      Int             @default(0)
  points      Int             @default(0)
  currentWeek Int             @default(1)
  currentDay  Int             @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  sessions    ChatSession[]
  progress    TopicProgress[]
}

model TopicProgress {
  id               String   @id @default(cuid())
  userId           String
  topicDay         Int
  completed        Boolean  @default(false)
  notes            String?  @db.Text
  redTeamReportUrl String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicDay])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  tokens    Int?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Week {
  id     Int     @id
  title  String
  topics Topic[]
}

model Topic {
  id            Int      @id
  day           Int      @unique
  weekId        Int
  title         String
  skill         String
  hoursPerDay   String
  difficulty    String
  systemDesign  String   @db.Text
  miniProject   String   @db.Text
  mediumProject String?  @db.Text
  bigProject    String?  @db.Text
  testing       String   @db.Text
  audit         String   @db.Text
  resource      String
  redTeamTask   String   @db.Text
  gapFixed      String?
  steps         String[]
  proTip        String?  @db.Text
  detailedSteps Json?
  week          Week     @relation(fields: [weekId], references: [id])
}

model Project {
  id        Int    @id
  milestone Int    @unique
  mini      String @db.Text
  medium    String @db.Text
  big       String @db.Text
}

model GraduationChecklist {
  id       String   @id @default(cuid())
  category String   @unique
  items    String[]
}

model DebuggingCategory {
  id          String          @id @default(cuid())
  name        String          @unique
  icon        String
  description String          @db.Text
  items       DebuggingItem[]
}

model DebuggingItem {
  id            String            @id @default(cuid())
  categoryId    String
  title         String
  description   String          @db.Text
  howItWorks    String          @db.Text
  tools         String[]
  practiceSteps String[]
  resources     Json // [{title, url}]
  category      DebuggingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model AgentSecretCategory {
  id          String        @id @default(cuid())
  name        String        @unique
  icon        String
  description String        @db.Text
  secrets     AgentSecret[]
}

model AgentSecret {
  id              String              @id @default(cuid())
  categoryId      String
  title           String
  description     String              @db.Text
  details         String              @db.Text
  examples        String[]
  resources       Json // [{title, url}]
  redTeamPlaybook String?             @db.Text
  category        AgentSecretCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model ProjectIdea {
  id          Int      @id @default(autoincrement())
  category    String   // e.g., "AI Backend", "RAG", "Agents"
  title       String
  description String   @db.Text
  difficulty  String   // Beginner, Intermediate, Advanced
  skills      String[] // Required skills
  techStack   String[] // Technologies to use
  videoUrl    String?
  resourceUrl String?
}

model Company {
  id           Int             @id @default(autoincrement())
  name         String
  type         String          // FAANG, Startup, Product, Service
  location     String
  roles        CompanyRole[]
  skillsNeeded CompanySkill[]
}

model CompanyRole {
  id         Int            @id @default(autoincrement())
  companyId   Int
  title      String         // e.g., "AI Engineer", "Backend Developer"
  level      String         // Intern, Junior, Senior, Staff
  minStipend Int?
  maxStipend Int?
  company    Company        @relation(fields: [companyId], references: [id])
}

model CompanySkill {
  id          Int     @id @default(autoincrement())
  companyId   Int
  skill       String
  importance  String  // Must-Have, Good-to-Have, Nice-to-Have
  company     Company @relation(fields: [companyId], references: [id])
}

model Syllabus {
  id          Int             @id @default(autoincrement())
  name        String          // e.g., "B.Tech CS 3rd Year"
  university  String
  semester    Int
  subjects    SyllabusSubject[]
}

model SyllabusSubject {
  id         Int      @id @default(autoincrement())
  syllabusId Int
  name       String   // e.g., "Database Management"
  topics     String[] // Topics covered in this subject
  mappedDays Int[]   // Day numbers from curriculum
  syllabus   Syllabus @relation(fields: [syllabusId], references: [id])
}

model VideoResource {
  id          Int      @id @default(autoincrement())
  topicDay    Int      // Links to which curriculum day
  title       String
  channel     String   // YouTube channel name
  url         String
  duration    String   // e.g., "15:30"
  type        String   // Tutorial, Project, Concept
}
